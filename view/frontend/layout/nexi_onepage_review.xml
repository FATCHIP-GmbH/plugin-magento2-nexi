<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" layout="1column" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>Review Order</title>
    </head>
    <update handle="checkout_onepage_review_item_renderers"/>
    <body>
        <referenceContainer name="content">
            <block class="Fatchip\Nexi\Block\Onepage\Review" name="computop_onepage_review" template="Fatchip_Nexi::onepage/review.phtml" cacheable="false">
                <block class="Magento\Framework\View\Element\Text\ListText" name="paypal.additional.actions">
                    <block class="Magento\Checkout\Block\Cart\Coupon" name="paypal.cart.coupon" as="coupon" template="Magento_Checkout::cart/coupon.phtml"/>
                </block>
                <block class="Fatchip\Nexi\Block\Onepage\Review\Details" name="computop_onepage_review_details" as="details" template="Fatchip_Nexi::onepage/review/details.phtml">
                    <block class="Magento\Framework\View\Element\RendererList" name="checkout.onepage.review.item.renderers" as="renderer.list"/>
                    <block class="Magento\Checkout\Block\Cart\Totals" name="computop_onepage_review_details_totals" as="totals" template="Fatchip_Nexi::onepage/review/totals.phtml"/>
                </block>
                <block class="Magento\CheckoutAgreements\Block\Agreements" name="computop_onepage_review_details_agreements" as="agreements" template="Magento_CheckoutAgreements::additional_agreements.phtml"/>
            </block>
        </referenceContainer>
        <block class="Fatchip\Nexi\Block\Onepage\Totals" name="additional.product.info" template="Magento_Theme::template.phtml" cacheable="false"/>
    </body>
</page>
